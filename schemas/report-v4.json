{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://elsas.it/schemas/report-v4.json",
  "title": "Elsas Daily Intelligence Report",
  "description": "Daily curated MCP ecosystem intelligence. Versioned schema for automated agent ingestion.",
  "type": "object",
  "required": ["report_id", "version", "_meta", "items"],
  "properties": {
    "report_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "_meta": {
      "type": "object",
      "required": ["generated_at"],
      "properties": {
        "generated_at": {"type": "string", "format": "date-time"},
        "curator": {"type": "string"},
        "total_items": {"type": "integer"}
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "category", "title", "summary", "why_it_matters", "importance", "relevant_for"],
        "properties": {
          "id": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}-(mcp|spec|sec)-\\d{3}$"},
          "category": {"type": "string", "enum": ["new_mcp", "spec_update", "security_incident"]},
          "title": {"type": "string", "minLength": 5},
          "summary": {"type": "string", "minLength": 10},
          "why_it_matters": {"type": "string", "minLength": 10},
          "importance": {"type": "integer", "minimum": 1, "maximum": 5},
          "relevant_for": {
            "type": "array",
            "items": {"type": "string", "enum": ["devops", "coding", "qa", "finance", "healthcare", "legal", "content", "security", "knowledge", "all"]}
          },
          "editor_pick": {"type": "boolean"},
          "delta": {"type": "string", "enum": ["NEW", "UPDATED", "RISING", "REPRINT"]},
          "risk_tier": {"type": ["string", "null"], "enum": ["low", "medium", "high", "critical", null]},
          "risk_dimensions": {
            "type": "object",
            "properties": {
              "infra_risk": {"type": "string", "enum": ["low", "medium", "high"]},
              "financial_risk": {"type": "string", "enum": ["low", "medium", "high"]},
              "credential_risk": {"type": "string", "enum": ["low", "medium", "high"]},
              "compliance_risk": {"type": "string", "enum": ["low", "medium", "high"]},
              "blast_radius": {"type": "string", "enum": ["low", "medium", "high"]}
            }
          },
          "bus_factor": {
            "type": "object",
            "properties": {
              "score": {"type": "integer", "minimum": 0, "maximum": 100},
              "level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
              "factors": {"type": "array", "items": {"type": "string"}}
            }
          },
          "install_command": {"type": "string"},
          "mcp_config": {"type": "object"},
          "community_signals": {
            "type": "object",
            "properties": {
              "github_stars": {"type": "integer"},
              "npm_downloads_7d": {"type": "integer"},
              "pypi_downloads_30d": {"type": "integer"},
              "npm_published": {"type": "boolean"}
            }
          },
          "sustainability": {
            "type": "object",
            "properties": {
              "last_commit": {"type": ["string", "null"]},
              "open_issues": {"type": "integer"},
              "release_cadence": {"type": "string", "enum": ["daily", "weekly", "monthly", "sporadic", "abandoned_risk", "unknown"]},
              "maintainer": {"type": "string", "enum": ["solo", "org", "unknown"]},
              "license": {"type": "string"},
              "data_available": {"type": "boolean"}
            }
          },
          "decision_guidance": {
            "type": "object",
            "properties": {
              "integrate": {"type": "string"},
              "skip_if": {"type": "string"}
            }
          },
          "tags": {"type": "array", "items": {"type": "string"}},
          "sources": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_items": {"type": "integer"},
        "new_mcp_count": {"type": "integer"},
        "spec_update_count": {"type": "integer"},
        "security_incident_count": {"type": "integer"},
        "max_importance": {"type": "integer"}
      }
    },
    "pricing": {
      "type": "object",
      "properties": {
        "current_price_usdc": {"type": "string"},
        "production_cost": {"type": "string"},
        "diy_cost": {"type": "string"}
      }
    }
  }
}
